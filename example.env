
# address of your realtime server (Socket.IO for sketch relay)
NEXT_PUBLIC_REALTIME_SERVER_ADDRESS="https://realtime.example.com"
NEXT_PUBLIC_REALTIME_SERVER_PORT=443

# LiveKit (WebRTC media)
NEXT_PUBLIC_LIVEKIT_SERVER_URL="wss://your-livekit-server.example.com"
LIVEKIT_API_KEY="your-api-key"
LIVEKIT_API_SECRET="your-api-secret"
LIVEKIT_SERVER_URL="https://your-livekit-server.example.com"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="http://backend.example.com"
NEXT_PUBLIC_SUPABASE_KEY="some-long-key-12345"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# OPTIONAL - add analytics through posthog
# NEXT_PUBLIC_POSTHOG_HOST=""https://us.i.posthog.com"
# NEXT_PUBLIC_POSTHOG_KEY="phc_your-api-key"
